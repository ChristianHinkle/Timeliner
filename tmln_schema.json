{
    "$id": "https://raw.githubusercontent.com/ChristianHinkle/Timeliner/refs/heads/main/tmln_schema.json",
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
        "refs": {
            "type": "object",
            "properties": {
                "entities": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "identifier": {
                                "type": "string"
                            }
                        },
                        "required": ["identifier"]
                    }
                },
                "animClips": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "identifier": {
                                "type": "string"
                            }
                        },
                        "required": ["identifier"]
                    }
                },
                "audioClips": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "identifier": {
                                "type": "string"
                            }
                        },
                        "required": ["identifier"]
                    }
                }
            }
        },
        "timeline": {
            "type": "object",
            "properties": {
                "timing": {
                    "type": "object",
                    "properties": {
                        "fps": {
                            "type": "integer",
                            "minimum": 0
                        },
                        "end": {
                            "type": "integer",
                            "minimum": 1
                        }
                    },
                    "required": ["fps", "end"]
                },
                "tracks": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "type": {
                                "type": "string"
                            },
                            "subtracks": {
                                "type": "array"
                            }
                        },
                        "required": ["id", "type"]
                    }
                },
                "keys": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "frame": {
                                "type": "integer",
                                "minimum": 1
                            },
                            "tracks": {
                                "type": "array"
                            }
                        },
                        "required": ["frame", "tracks"]
                    }
                }
            },
            "required": ["timing"]
        }
    },
    "required": ["timeline"]
}
